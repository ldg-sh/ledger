# Server
PORT=3001
NODE_ENV=development

# Auth
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=your-secret-key-here

# Server-to-server authentication
SERVER_KEY=your-server-key-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ledger_auth

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@ledger.app

# OAuth - Google
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

# Backend integration
BACKEND_INTERNAL_URL=http://localhost:8080

# Trusted origins (comma-separated, optional)
# TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
